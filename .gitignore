# Python
__pycache__/
*.py[cod]
*.so

# Environments
.env
.venv/
venv/

# Jupyter
.ipynb_checkpoints/

# OS files
.DS_Store

# Build / packaging
build/
dist/
*.egg-info/

# Logs
*.log

# External dependencies
external/*
!external/README.md
!external/.gitkeep
external/Geneformer/

# Data directories
data/raw/
data/processed/

# Data safety net (also covers future subfolders in data/)
data/**/*.h5ad
data/**/*.h5
data/**/*.loom
data/**/*.npy
data/**/*.npz
data/**/*.dataset
data/**/*.arrow
data/**/*.parquet
data/**/*.pt
data/**/*.pth
data/**/*.bin
data/**/*.safetensors
data/**/*.ckpt

# Large single-cell and model artifacts
*.h5ad
*.h5
*.loom
*.npy
*.npz
*.pt
*.pth
*.bin
*.safetensors
*.ckpt

# Results artifacts
# Ignore all run outputs by default.
experiments/**/results/**

# Keep folder structure tracked.
!experiments/**/results/
!experiments/**/results/**/
!experiments/**/results/**/.gitkeep

# Allow only lightweight curated reports to be committed.
!experiments/**/results/reports/
!experiments/**/results/reports/*.md
!experiments/**/results/reports/*.json
!experiments/**/results/reports/*.tsv
